{
  "name": "@eleven-labs/nest-profiler-axios",
  "version": "1.0.0-alpha.5",
  "description": "DEPRECATED — renamed to @eleven-labs/nest-profiler-http. This package re-exports it.",
  "keywords": [
    "nestjs",
    "axios",
    "http-client",
    "profiler",
    "deprecated",
    "nest-profiler"
  ],
  "license": "MIT",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "repo-build",
    "clean": "repo-clean dist coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@eleven-labs/nest-profiler-http": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@eleven-labs/nest-profiler": ">=1.0.0-alpha.1",
    "nestjs-cls": "^4.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/axios": {
      "optional": true
    },
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eleven-labs/nest-profiler": "workspace:*",
    "@eleven-labs/nest-profiler-http": "workspace:*",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.3",
    "@repo/build": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "jest": "^30.4.2",
    "nestjs-cls": "^4.5.0",
    "reflect-metadata": "^0.2.2",
    "ts-jest": "^29.3.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "@repo/jest-config",
    "rootDir": ".",
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage"
  },
  "author": {
    "name": "Fabien Pasquet",
    "url": "https://github.com/fpasquet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-labs/nest-profiler.git",
    "directory": "packages/nest-profiler-axios"
  },
  "homepage": "https://nest-profiler.eleven-labs.com/docs/packages/nest-profiler-http",
  "bugs": {
    "url": "https://github.com/eleven-labs/nest-profiler/issues"
  },
  "contributors": [
    {
      "name": "Eleven Labs",
      "url": "https://eleven-labs.com"
    }
  ],
  "funding": "https://eleven-labs.com"
}
