<%
  const queries = data || [];
  const totalDuration = queries.reduce((sum, q) => sum + q.duration, 0);
  const rowsRead = queries.reduce((sum, q) => sum + (q.type === 'SELECT' && typeof q.rowCount === 'number' ? q.rowCount : 0), 0);
  const hasRowsRead = queries.some(q => q.type === 'SELECT' && typeof q.rowCount === 'number');
  const hasTag = (q, id) => (q.tags || []).some(t => t.id === id);
  const slowCount = queries.filter(q => hasTag(q, 'slow')).length;
  const nPlusOneGroups = new Set(queries.filter(q => hasTag(q, 'n-plus-one') && q.fingerprint).map(q => q.fingerprint));
  const slowSev = sevOfTag(queries, 'slow');
  const nPlusOneSev = sevOfTag(queries, 'n-plus-one');
  // Worst severity among a row's performance tags (excluding `error`, surfaced separately) — tints the row.
  const rowSev = (q) => {
    let best = null;
    for (const t of (q.tags || [])) {
      if (t.id === 'error') continue;
      if (best === null || (t.severity === 'danger') || (t.severity === 'warning' && best === 'info')) best = t.severity;
    }
    return best;
  };
  const typeColors = {
    SELECT: 'badge-get',
    INSERT: 'badge-post',
    UPDATE: 'badge-put',
    DELETE: 'badge-delete',
    OTHER:  'badge-default',
  };
%>

<div class="flex items-center justify-between mb-4">
  <div class="flex items-center gap-4 text-xs text-foreground-muted">
    <span><strong class="text-foreground"><%= queries.length %></strong> quer<%= queries.length !== 1 ? 'ies' : 'y' %></span>
    <span><strong class="text-foreground"><%= totalDuration %></strong>ms total</span>
    <% if (hasRowsRead) { %>
      <span><strong class="text-foreground"><%= rowsRead %></strong> row<%= rowsRead !== 1 ? 's' : '' %> read</span>
    <% } %>
    <% if (slowCount > 0) { %>
      <span class="<%= sevTextClass(slowSev) %>"><strong><%= slowCount %></strong> slow</span>
    <% } %>
    <% if (nPlusOneGroups.size > 0) { %>
      <span class="<%= sevTextClass(nPlusOneSev) %>"><strong><%= nPlusOneGroups.size %></strong> N+1</span>
    <% } %>
  </div>
</div>

<% if (queries.length === 0) { %>
  <div class="py-8 text-center bg-surface-muted border border-line rounded-lg">
    <p class="text-foreground-muted text-sm">No queries executed during this request.</p>
  </div>
<% } else { %>
  <div class="rounded-lg border border-line overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="bg-surface-muted border-b border-line">
          <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest w-16">Type</th>
          <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Query</th>
          <th class="text-right py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest w-24">Duration</th>
          <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest w-20">Time</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-line-subtle">
        <%
          const canExplain = typeof explainCollectors !== 'undefined'
            && typeof collectorName !== 'undefined'
            && explainCollectors.includes(collectorName);
        %>
        <% queries.forEach((q, qIndex) => { %>
          <tr class="hover:bg-surface-muted transition-colors <%= sevBgClass(rowSev(q)) %>">
            <td class="py-2 px-4 whitespace-nowrap align-top">
              <span class="px-1.5 py-0.5 rounded text-2xs font-bold tracking-wide <%= typeColors[q.type] || 'badge-default' %>"><%= q.type %></span>
              <% if (q.streaming) { %>
                <span class="block mt-1 px-1.5 py-0.5 rounded text-2xs font-bold tracking-wide badge-default">stream</span>
              <% } %>
            </td>
            <td class="py-2 px-4 align-top">
              <div class="flex items-start justify-between gap-2">
                <code class="text-xs text-code-text leading-relaxed break-all"><% if (typeof highlightSql === 'function') { %><%- highlightSql(q.sql) %><% } else { %><%= q.sql %><% } %></code>
                <span class="shrink-0"><%- copyBtn(interpolateSql(q.sql, q.parameters), 'Copy SQL') %></span>
              </div>
              <% if (q.tags && q.tags.length > 0) { %>
                <div class="mt-1.5 flex flex-wrap gap-1"><%- tagBadges(q.tags) %></div>
              <% } %>
              <% if (q.rowCount !== undefined || q.connection || q.database) { %>
                <div class="mt-1.5 flex flex-wrap items-center gap-x-2 gap-y-1 text-2xs">
                  <% if (q.rowCount !== undefined) { %>
                    <% const zeroWrite = q.rowCount === 0 && (q.type === 'UPDATE' || q.type === 'DELETE'); %>
                    <span class="tabular-nums <%= zeroWrite ? 'text-amber-600 dark:text-amber-400' : 'text-foreground-muted' %>">
                      <span class="font-semibold"><%= q.rowCount %></span> row<%= q.rowCount !== 1 ? 's' : '' %>
                    </span>
                  <% } %>
                  <% if (q.connection || q.database) { %>
                    <span class="inline-flex items-center gap-1 rounded border border-line-subtle px-1.5 py-0.5 text-foreground-faint" title="Connection">
                      <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75" />
                      </svg>
                      <% if (q.connection) { %><span class="tabular-nums text-foreground-muted"><%= q.connection %></span><% } %>
                      <% if (q.database) { %><% if (q.connection) { %><span class="text-line" aria-hidden="true">/</span><% } %><span class="text-foreground-muted font-medium"><%= q.database %></span><% } %>
                    </span>
                  <% } %>
                </div>
              <% } %>
              <% if (q.parameters && q.parameters.length > 0) { %>
                <div class="mt-2">
                  <div class="text-2xs text-foreground-muted font-medium mb-0.5">Parameters:</div>
                  <pre class="bg-surface-muted border border-line rounded px-2 py-1 text-xs overflow-x-auto m-0"><code class="language-json"><%= toJson(q.parameters) %></code></pre>
                </div>
              <% } %>
              <% if (q.error) { %>
                <div class="mt-1 text-danger text-2xs">Error: <%= q.error %></div>
              <% } %>
              <% if (canExplain) { %>
                <div class="mt-2">
                  <button type="button"
                    data-explain="<%= link(profilerPath + '/' + profile.token + '/explain/' + collectorName + '/' + qIndex) %>"
                    class="inline-flex items-center gap-1 rounded border border-line px-1.5 py-0.5 text-2xs font-medium text-foreground-muted hover:text-foreground hover:border-line-active transition-colors">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23-.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" /></svg>
                    <span>Explain</span>
                  </button>
                  <div data-explain-target class="mt-2 hidden"></div>
                </div>
              <% } %>
            </td>
            <td class="py-2 px-4 text-right align-top">
              <% const slowTag = (q.tags || []).find(t => t.id === 'slow'); %>
              <span class="text-xs tabular-nums <%= slowTag ? sevTextClass(slowTag.severity) + ' font-bold' : 'text-foreground-secondary' %>"><%= q.duration %>ms</span>
              <% if (slowTag) { %>
                <span class="block text-2xs opacity-70 <%= sevTextClass(slowTag.severity) %>">slow</span>
              <% } else if (q.streaming && q.duration === 0) { %>
                <span class="block text-2xs text-foreground-faint" title="Duration is not measured for this streaming read (the query is logged before its rows are consumed).">not timed (stream)</span>
              <% } %>
            </td>
            <td class="py-2 px-4 text-foreground-faint text-2xs tabular-nums align-top whitespace-nowrap"><%= timeOnly(q.startedAt) %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

<style>
  .sql-keyword { color: #818cf8; font-weight: 600; }
</style>
