<!DOCTYPE html>
<html lang="en">
<%- include('_head') %>
<body class="bg-background text-foreground min-h-screen font-mono text-sm antialiased">
  <%- include('_nav') %>
  <main class="max-w-7xl mx-auto px-6 py-8 pb-16">

    <%
      /* ── Precompute panel map ──────────────────────────────────────────── */
      const collectorPanelMap = {};
      if (collectorPanels) {
        for (const p of collectorPanels) collectorPanelMap[p.name] = p;
      }

      /* The entrypoint type contributes the primary tabs (Request/Response for
         HTTP, Command for a CLI command, Message for a consumed message…). The
         universal tabs (Performance/Logs/Exceptions) follow for every kind. */
      const UNIVERSAL_TABS = [
        {
          name: 'performance',
          label: 'Performance',
          icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>',
        },
        {
          name: 'logs',
          label: 'Logs',
          icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h7"/></svg>',
          badge: profile.logs.length > 0 ? profile.logs.length : null,
        },
        {
          name: 'exceptions',
          label: 'Exceptions',
          icon: '<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>',
          badge: profile.exceptions.length > 0 ? profile.exceptions.length : null,
          badgeClass: 'bg-danger-bg text-danger border-danger-line',
        },
      ];

      const builtinTabs = [...(entrypointTabs || []), ...UNIVERSAL_TABS];
    %>

    <!-- ── Breadcrumb ────────────────────────────────────────────────────── -->
    <nav class="flex items-center gap-2 text-xs mb-6 flex-wrap">
      <a href="<%= profilerPath %>" class="text-foreground-muted hover:text-foreground transition-colors">Profiles</a>
      <span class="text-foreground-faint">/</span>
      <span class="px-2 py-0.5 rounded text-2xs font-bold tracking-wide <%= summary.badgeClass || 'badge-default' %>"><%= summary.badge %></span>
      <span class="text-foreground-secondary truncate max-w-xs"><%= summary.text %></span>
      <span class="text-foreground-faint">/</span>
      <code class="text-foreground-secondary bg-surface border border-line px-2 py-0.5 rounded"><%= profile.token.slice(0, 8) %></code>
      <% if (profile.route) { %>
        <span class="text-foreground-faint">·</span>
        <span class="text-foreground-faint"><%= profile.route.controller %>::<%= profile.route.handler %></span>
      <% } %>
      <a href="<%= profilerPath %>/<%= profile.token %>/data"
         download="profile-<%= profile.token.slice(0, 8) %>.json"
         class="ml-auto flex items-center gap-1 px-2.5 py-1 rounded border border-line text-foreground-muted hover:text-foreground hover:border-line-active transition-colors text-2xs">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        Export JSON
      </a>
    </nav>

    <!-- ── Two-column layout ─────────────────────────────────────────────── -->
    <div class="flex gap-5 items-start">

      <!-- ── Left aside — navigation ──────────────────────────────────────── -->
      <aside class="w-52 shrink-0 sticky top-16">
        <nav class="bg-surface border border-line rounded-xl overflow-hidden">

          <!-- Built-in tabs -->
          <div class="px-4 pt-3 pb-1.5">
            <span class="text-2xs text-foreground-faint uppercase tracking-widest font-medium">Profile</span>
          </div>

          <% for (const bt of builtinTabs) { %>
            <%
              const isActive = activeTab === bt.name;
              const badge = bt.badge ?? null;
              const isEmpty = bt.badge === null;
            %>
            <a href="<%= profilerPath %>/<%= profile.token %>?tab=<%= bt.name %>"
               class="flex items-center gap-2.5 pl-3 pr-3 py-2 text-xs font-medium transition-colors border-l-2
                 <%= isActive
                   ? 'border-nest text-nest bg-surface-active'
                   : isEmpty
                     ? 'border-transparent text-foreground-faint hover:text-foreground-muted hover:bg-surface-muted'
                     : 'border-transparent text-foreground-muted hover:text-foreground hover:bg-surface-muted' %>">
              <% if (bt.icon) { %><span class="w-3.5 h-3.5 shrink-0 <%= isEmpty && !isActive ? 'opacity-50' : '' %>"><%- bt.icon %></span><% } %>
              <span class="flex-1"><%= bt.label %></span>
              <% if (badge !== null) { %>
                <span class="px-1.5 py-0.5 rounded-full text-2xs font-bold border
                  <%= bt.badgeClass
                    ? bt.badgeClass
                    : isActive
                      ? 'bg-nest/10 text-nest border-nest/20'
                      : 'bg-surface-muted text-foreground-muted border-line' %>"><%= badge %></span>
              <% } %>
            </a>
          <% } %>

          <!-- Collector tabs -->
          <% if (collectorPanels && collectorPanels.length > 0) { %>
            <div class="mt-3 pt-3 border-t border-line px-4 pb-1.5">
              <span class="text-2xs text-foreground-faint uppercase tracking-widest font-medium">Collectors</span>
            </div>
            <% for (const panel of collectorPanels) { %>
              <%
                const isActive = activeTab === panel.name;
                const badge = (panel.badgeValue !== null && panel.badgeValue !== undefined) ? panel.badgeValue : null;
                // badgeValue === null (strict) means getBadgeValue returned null = no data for this request
                const isEmpty = panel.badgeValue === null;
              %>
              <a href="<%= profilerPath %>/<%= profile.token %>?tab=<%= panel.name %>"
                 class="flex items-center gap-2.5 pl-3 pr-3 py-2 text-xs font-medium transition-colors border-l-2
                   <%= isActive
                     ? 'border-nest text-nest bg-surface-active'
                     : isEmpty
                       ? 'border-transparent text-foreground-faint hover:text-foreground-muted hover:bg-surface-muted'
                       : 'border-transparent text-foreground-muted hover:text-foreground hover:bg-surface-muted' %>">
                <% if (panel.icon) { %><span class="w-3.5 h-3.5 shrink-0 <%= isEmpty && !isActive ? 'opacity-50' : '' %>"><%- panel.icon %></span><% } %>
                <span class="flex-1"><%= panel.label %></span>
                <% if (badge !== null) { %>
                  <span class="px-1.5 py-0.5 rounded-full text-2xs font-bold border
                    <%= isActive
                      ? 'bg-nest/10 text-nest border-nest/20'
                      : 'bg-surface-muted text-foreground-muted border-line' %>"><%= badge %></span>
                <% } %>
              </a>
            <% } %>
          <% } %>

          <div class="h-2"></div>
        </nav>
      </aside>

      <!-- ── Right panel — content ─────────────────────────────────────────── -->
      <div class="flex-1 min-w-0 bg-surface border border-line rounded-xl">
        <div class="p-6 min-h-56">

          <% if (activeTab === 'performance') { %>

            <%
              const heapUsed = profile.performance.heapUsed;
              const dur      = profile.performance.duration;
              const durClass = dur === undefined ? 'dur-none'
                : dur < 100 ? 'dur-fast'
                : dur < 500 ? 'dur-medium'
                : 'dur-slow';
            %>

            <div class="grid grid-cols-2 gap-4 mb-8">
              <div class="bg-surface-muted border border-line rounded-lg p-4">
                <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-3">Duration</p>
                <p class="<%= durClass %> text-2xl font-bold tabular-nums leading-none">
                  <%= dur !== undefined ? dur : '—' %><% if (dur !== undefined) { %><span class="text-sm font-normal text-foreground-faint ml-1">ms</span><% } %>
                </p>
              </div>
              <div class="bg-surface-muted border border-line rounded-lg p-4">
                <div class="flex items-start justify-between gap-2">
                  <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-3">Process heap</p>
                  <span class="text-2xs px-1.5 py-0.5 rounded bg-surface border border-line text-foreground-faint shrink-0">at request start</span>
                </div>
                <p class="text-foreground text-xl font-bold tabular-nums leading-none"><%= mb(heapUsed) %></p>
                <p class="text-foreground-faint text-2xs mt-2 leading-relaxed">Process-wide V8 heap — not isolated per request.</p>
              </div>
            </div>

            <section>
              <h2 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold mb-3">Timeline</h2>
              <div class="bg-surface-muted border border-line rounded-lg divide-y divide-line-subtle">
                <div class="flex items-center justify-between px-4 py-2.5 text-xs">
                  <span class="text-foreground-muted">Start</span>
                  <code class="text-foreground-secondary tabular-nums"><%= isoDate(profile.performance.startTime) %></code>
                </div>
                <% if (dur !== undefined) { %>
                  <div class="flex items-center justify-between px-4 py-2.5 text-xs">
                    <span class="text-foreground-muted">End</span>
                    <code class="text-foreground-secondary tabular-nums"><%= isoDate(profile.performance.startTime + dur) %></code>
                  </div>
                <% } %>
              </div>
            </section>

          <% } else if (activeTab === 'logs') { %>

            <% if (profile.logs.length === 0) { %>
              <div class="py-8 text-center">
                <p class="text-foreground-muted text-sm mb-2">No log entries captured.</p>
                <p class="text-foreground-faint text-xs">
                  Use <code class="bg-surface-muted border border-line px-1.5 py-0.5 rounded">profilerService.createLogger()</code> in
                  <code class="bg-surface-muted border border-line px-1.5 py-0.5 rounded">main.ts</code> to enable log capture.
                </p>
              </div>
            <% } else { %>
              <div class="rounded-lg border border-line overflow-hidden">
                <table class="w-full">
                  <thead>
                    <tr class="bg-surface-muted border-b border-line">
                      <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Time</th>
                      <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Level</th>
                      <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Message</th>
                      <th class="text-left py-2.5 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Context</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-line-subtle">
                    <% for (const entry of profile.logs) { %>
                      <tr class="hover:bg-surface-muted transition-colors">
                        <td class="py-2 px-4 text-foreground-faint text-xs whitespace-nowrap tabular-nums align-top"><%= timeOnly(entry.timestamp) %></td>
                        <td class="py-2 px-4 whitespace-nowrap align-top">
                          <span class="px-1.5 py-0.5 rounded text-2xs font-bold tracking-wide <%= logLevelClass(entry.level) %>"><%= entry.level.toUpperCase() %></span>
                        </td>
                        <td class="py-2 px-4 text-foreground text-xs break-all align-top w-full">
                          <%= entry.message %>
                          <% if (entry.data !== undefined) { %>
                            <pre class="bg-surface-muted border border-line rounded px-2 py-1 mt-1.5 text-xs overflow-x-auto m-0"><code class="language-json"><%= toJson(entry.data) %></code></pre>
                          <% } %>
                        </td>
                        <td class="py-2 px-4 text-foreground-muted text-xs whitespace-nowrap align-top"><%= entry.context || '' %></td>
                      </tr>
                    <% } %>
                  </tbody>
                </table>
              </div>
            <% } %>

          <% } else if (activeTab === 'exceptions') { %>

            <% if (profile.exceptions.length === 0) { %>
              <div class="py-8 text-center">
                <p class="text-success text-sm mb-1">No exceptions</p>
                <p class="text-foreground-faint text-xs">This request completed without throwing any exceptions.</p>
              </div>
            <% } else { %>
              <div class="space-y-3">
                <% for (const ex of profile.exceptions) { %>
                  <%
                    const isGqlError = ex.name === 'GraphQLError';
                    const cardClass    = isGqlError ? 'bg-amber-50 dark:bg-amber-950/20 border-amber-200 dark:border-amber-800/40'   : 'bg-danger-bg border-danger-line';
                    const nameClass    = isGqlError ? 'text-amber-600 dark:text-amber-400'   : 'text-danger';
                    const msgClass     = isGqlError ? 'text-amber-600/70 dark:text-amber-400/70' : 'text-danger/70';
                    const borderClass  = isGqlError ? 'border-amber-200/60 dark:border-amber-800/30' : 'border-danger-line-subtle';
                  %>
                  <div class="<%= cardClass %> border rounded-lg p-4">
                    <div class="flex items-start justify-between gap-4 mb-1">
                      <div class="min-w-0 flex items-center gap-2">
                        <% if (isGqlError) { %>
                          <svg class="w-3.5 h-3.5 shrink-0 text-amber-500 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
                        <% } %>
                        <div class="min-w-0">
                          <span class="<%= nameClass %> font-bold text-xs"><%= ex.name %></span>
                          <p class="<%= msgClass %> text-xs mt-0.5 break-words"><%= ex.message %></p>
                        </div>
                      </div>
                      <time class="text-foreground-faint text-xs whitespace-nowrap tabular-nums shrink-0"><%= isoDate(ex.timestamp) %></time>
                    </div>
                    <% if (ex.stack) { %>
                      <pre class="mt-3 pt-3 text-xs text-foreground-muted overflow-x-auto leading-relaxed border-t <%= borderClass %>"><%= ex.stack %></pre>
                    <% } %>
                  </div>
                <% } %>
              </div>
            <% } %>

          <% } else if (entrypointTabTemplate) { %>

            <%- include(entrypointTabTemplate, { profile, methodClass, gqlTypeClass, statusClass, logLevelClass, isoDate, timeOnly, toJson, kvTable, highlightSql, mb }) %>

          <% } else { %>

            <%
              const activePanel = collectorPanelMap[activeTab];
            %>
            <% if (activePanel && activePanel.templatePath) { %>
              <%- include(activePanel.templatePath, { panel: activePanel, data: collectorData, profile, highlightSql, toJson, isoDate, timeOnly }) %>
            <% } else if (typeof collectorData !== 'undefined') { %>
              <pre class="bg-surface-muted border border-line rounded-lg p-4 text-xs text-code-text overflow-x-auto leading-relaxed"><%= toJson(collectorData) %></pre>
            <% } else { %>
              <p class="text-foreground-muted text-sm italic">Unknown panel: <code><%= activeTab %></code></p>
            <% } %>

          <% } %>

        </div>
      </div>

    </div><!-- end two-column -->

  </main>
</body>
</html>
