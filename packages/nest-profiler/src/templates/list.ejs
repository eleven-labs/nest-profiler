<!DOCTYPE html>
<html lang="en">
<%- include('_head') %>
<body class="bg-background text-foreground min-h-screen font-mono text-sm antialiased">
  <%- include('_nav') %>
  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="mb-6">
      <h1 class="text-base font-semibold text-foreground">Recent Profiles</h1>
      <p class="text-foreground-muted text-xs mt-0.5">Profiles captured by the profiler</p>
    </div>

    <%
      const sectionViewList = typeof sectionViews !== 'undefined' && sectionViews ? sectionViews : [];
      const globalViewList = typeof globalViews !== 'undefined' && globalViews ? globalViews : [];
      // Active/inactive classes for a sidebar link, shared by section sub-items and global items.
      const navLink = (isActive) => isActive
        ? 'border-nest text-nest bg-surface-active'
        : 'border-transparent text-foreground-muted hover:text-foreground hover:bg-surface-muted';
    %>

    <!-- ── Two-column layout (stacks to one column on mobile) ─────────────── -->
    <div class="flex flex-col md:flex-row gap-5 md:items-start">

      <!-- ── Left aside — view navigation ─────────────────────────────────── -->
      <aside class="w-full md:w-52 shrink-0 md:sticky md:top-16">
        <nav class="bg-surface border border-line rounded-xl overflow-hidden py-1">

          <!-- Profiling group — one sub-item per registered list section (HTTP, GraphQL…) -->
          <div class="px-4 pt-2 pb-1">
            <span class="text-2xs text-foreground-faint uppercase tracking-widest font-medium">Profiling</span>
          </div>
          <% for (const v of sectionViewList) { %>
            <a href="<%= link(profilerPath + '?view=' + v.key) %>"
               class="flex items-center gap-2.5 pl-6 pr-3 py-2 text-xs font-medium transition-colors border-l-2 <%= navLink(v.key === activeView) %>">
              <span class="flex-1 truncate"><%= v.label %></span>
              <% if (typeof v.count === 'number') { %><span class="shrink-0 text-2xs tabular-nums px-1.5 py-0.5 rounded-full bg-surface-muted border border-line text-foreground-faint"><%= v.count %></span><% } %>
            </a>
          <% } %>

          <!-- Global panels (Config, Routes, Schemas…) -->
          <% if (globalViewList.length > 0) { %>
            <div class="mx-3 my-1.5 border-t border-line-subtle"></div>
            <% for (const v of globalViewList) { %>
              <a href="<%= link(profilerPath + '?view=' + v.key) %>"
                 class="flex items-center gap-2.5 pl-3 pr-3 py-2 text-xs font-medium transition-colors border-l-2 <%= navLink(v.key === activeView) %>">
                <% if (v.icon) { %><span class="w-3.5 h-3.5 shrink-0"><%- v.icon %></span><% } %>
                <span class="flex-1 truncate"><%= v.label %></span>
                <% if (typeof v.count === 'number') { %><span class="shrink-0 text-2xs tabular-nums px-1.5 py-0.5 rounded-full bg-surface-muted border border-line text-foreground-faint"><%= v.count %></span><% } %>
              </a>
            <% } %>
          <% } %>

        </nav>
      </aside>

      <!-- ── Right panel — active view ─────────────────────────────────────── -->
      <div class="flex-1 min-w-0">

        <% if (typeof activeSection !== 'undefined' && activeSection) { %>

          <% if (heapSeries && heapSeries.length >= 2) { %>
            <%
              const heapMin  = Math.min(...heapSeries);
              const heapMax  = Math.max(...heapSeries);
              const heapSpan = heapMax - heapMin || 1;
              const heapLast = heapSeries[heapSeries.length - 1];
              // Trend: compare last 20% vs first 20% of the series.
              const chunk = Math.max(1, Math.floor(heapSeries.length / 5));
              const heapAvgFirst = heapSeries.slice(0, chunk).reduce((s, v) => s + v, 0) / chunk;
              const heapAvgLast  = heapSeries.slice(-chunk).reduce((s, v) => s + v, 0) / chunk;
              const heapTrend    = heapAvgLast - heapAvgFirst;
              const trendClass   = heapTrend > 5 * 1024 * 1024 ? 'text-danger' : heapTrend > 1024 * 1024 ? 'dur-medium' : 'text-foreground-muted';
              const trendLabel   = heapTrend > 5 * 1024 * 1024 ? '↑ potential leak' : heapTrend > 1024 * 1024 ? '↑ growing' : '~ stable';
            %>
            <div class="mb-4 bg-surface border border-line rounded-xl p-4">
              <div class="flex items-center justify-between mb-3 flex-wrap gap-2">
                <div class="flex items-center gap-3">
                  <span class="text-xs font-semibold text-foreground">Process heap</span>
                  <span class="text-2xs px-1.5 py-0.5 rounded bg-surface-muted border border-line text-foreground-faint">last <%= heapSeries.length %> requests</span>
                </div>
                <div class="flex items-center gap-4 text-xs tabular-nums">
                  <span class="text-foreground-faint">min <span class="text-foreground"><%= mb(heapMin) %></span></span>
                  <span class="text-foreground-faint">max <span class="text-foreground"><%= mb(heapMax) %></span></span>
                  <span class="text-foreground-faint">now <span class="text-foreground font-medium"><%= mb(heapLast) %></span></span>
                  <span class="<%= trendClass %> font-medium"><%= trendLabel %></span>
                </div>
              </div>
              <div class="flex items-end gap-px h-10">
                <% for (const v of heapSeries) { %>
                  <%
                    const pct = Math.round(((v - heapMin) / heapSpan) * 80) + 20;
                    const barClass = v > heapMin + heapSpan * 0.8 ? 'bg-danger/60' : v > heapMin + heapSpan * 0.5 ? 'bg-amber-400/60' : 'bg-nest/40';
                  %>
                  <div class="flex-1 rounded-t-sm <%= barClass %>" style="height:<%= pct %>%"
                       title="<%= mb(v) %>"></div>
                <% } %>
              </div>
              <p class="text-foreground-faint text-2xs mt-2">Process-wide V8 heap at request start. A rising trend indicates a memory leak.</p>
            </div>
          <% } %>

          <%
            // The single active list section (its own page); filter fields are namespaced by key.
            const s = activeSection;
            const sectionHelpers = { profilerPath, link, methodClass, gqlTypeClass, statusClass, isoDate, toJson, timeOnly, tagBadges };
            const inputClass = 'bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground focus:outline-none focus:border-nest';
            const filteredTotal = s.pagination ? s.pagination.filteredTotal : s.profiles.length;
            const plural = s.total !== 1 ? 's' : '';
            const countText = filteredTotal !== s.total
              ? `${filteredTotal} of ${s.total} ${s.itemLabel}${plural}`
              : `${s.total} ${s.itemLabel}${plural}`;
          %>
          <div class="rounded-xl border border-line bg-surface overflow-hidden">
            <div class="flex items-center justify-between gap-3 px-4 py-3 bg-surface-muted border-b border-line">
              <div class="flex items-center gap-2 min-w-0">
                <span class="text-xs font-semibold text-foreground shrink-0"><%= s.title %></span>
                <% if (s.description) { %>
                  <span class="text-foreground-faint text-2xs ml-1 font-normal truncate">— <%= s.description %></span>
                <% } %>
              </div>
              <span class="text-xs text-foreground-secondary bg-surface border border-line px-3 py-1.5 rounded-full tabular-nums shrink-0"><%= countText %></span>
            </div>
            <div class="p-4">
              <% if (s.filterDefs && s.filterDefs.length > 0) { %>
                <%# The filter bar submits a GET that stays on this view (hidden `view` field). %>
                <form data-profiler-filters method="GET" action="<%= profilerPath %>" class="mb-4 flex flex-wrap gap-2 items-end bg-surface-muted border border-line rounded-xl p-4">
                  <input type="hidden" name="view" value="<%= activeView %>">
                  <% linkQueryPairs.forEach((p) => { %><input type="hidden" name="<%= p.name %>" value="<%= p.value %>"><% }) %>
                  <% for (const def of s.filterDefs) { %>
                    <% const value = (s.filterValues || {})[def.key]; %>
                    <% const fieldName = s.filterPrefix + '_' + def.key; %>
                    <% if (def.control === 'checkbox') { %>
                      <label class="flex items-center gap-1.5 text-xs text-foreground cursor-pointer self-end py-1.5">
                        <input type="checkbox" name="<%= fieldName %>" value="1" <%= value ? 'checked' : '' %> class="accent-nest" />
                        <%= def.label %>
                      </label>
                    <% } else { %>
                      <div class="flex flex-col gap-1">
                        <label class="text-foreground-faint text-2xs uppercase tracking-widest"><%= def.label %></label>
                        <% if (def.control === 'select') { %>
                          <select name="<%= fieldName %>" class="<%= inputClass %>">
                            <% for (const opt of (def.options || [])) { %>
                              <option value="<%= opt.value %>" <%= value === opt.value ? 'selected' : '' %>><%= opt.label %></option>
                            <% } %>
                          </select>
                        <% } else { %>
                          <input type="<%= def.control === 'number' ? 'number' : 'text' %>" name="<%= fieldName %>"
                                 value="<%= value || '' %>"
                                 placeholder="<%= def.placeholder || '' %>"
                                 class="<%= inputClass %> <%= def.control === 'number' ? 'w-24' : 'w-44' %>" />
                        <% } %>
                      </div>
                    <% } %>
                  <% } %>
                  <div class="flex gap-2">
                    <button type="submit" class="px-3 py-1.5 rounded bg-nest text-white text-xs font-medium hover:opacity-90 transition-opacity">Filter</button>
                    <a href="<%= s.resetHref %>" class="px-3 py-1.5 rounded border border-line text-foreground-muted text-xs hover:text-foreground hover:border-line-active transition-colors">Reset</a>
                  </div>
                </form>
              <% } %>

              <%- include(s.templatePath, { ...sectionHelpers, profiles: s.profiles }) %>

              <% if (s.pagination && s.pagination.pageCount > 1) { %>
                <% const pg = s.pagination; %>
                <nav class="mt-3 flex items-center justify-between gap-3 text-xs" aria-label="Pagination">
                  <span class="text-foreground-faint tabular-nums">
                    Showing <%= pg.rangeStart %>–<%= pg.rangeEnd %> of <%= pg.filteredTotal %>
                  </span>
                  <div class="flex items-center gap-2">
                    <% if (pg.prevHref) { %>
                      <a href="<%= pg.prevHref %>" rel="prev" class="px-2.5 py-1 rounded border border-line text-foreground-muted hover:text-foreground hover:border-line-active transition-colors">‹ Prev</a>
                    <% } else { %>
                      <span class="px-2.5 py-1 rounded border border-line-subtle text-foreground-faint cursor-not-allowed" aria-disabled="true">‹ Prev</span>
                    <% } %>
                    <span class="text-foreground-secondary tabular-nums px-1">Page <%= pg.page %> / <%= pg.pageCount %></span>
                    <% if (pg.nextHref) { %>
                      <a href="<%= pg.nextHref %>" rel="next" class="px-2.5 py-1 rounded border border-line text-foreground-muted hover:text-foreground hover:border-line-active transition-colors">Next ›</a>
                    <% } else { %>
                      <span class="px-2.5 py-1 rounded border border-line-subtle text-foreground-faint cursor-not-allowed" aria-disabled="true">Next ›</span>
                    <% } %>
                  </div>
                </nav>
              <% } %>
            </div>
          </div>

        <% } else if (typeof activeGlobalPanel !== 'undefined' && activeGlobalPanel) { %>

          <!-- ── Global-collector panel (Config, Routes, Schemas…) ───────────── -->
          <div class="bg-surface border border-line rounded-xl overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 bg-surface-muted border-b border-line">
              <% if (activeGlobalPanel.icon) { %><span class="w-3.5 h-3.5 shrink-0 text-foreground-muted"><%- activeGlobalPanel.icon %></span><% } %>
              <span class="text-xs font-semibold text-foreground"><%= activeGlobalPanel.label %></span>
              <span class="text-foreground-faint text-2xs ml-1 font-normal">— global, captured at startup</span>
            </div>
            <div class="p-4">
              <% if (activeGlobalPanel.templatePath) { %>
                <%- include(activeGlobalPanel.templatePath, { panel: activeGlobalPanel, data: activeGlobalPanel.data, highlightSql, toJson, isoDate, timeOnly }) %>
              <% } else { %>
                <pre class="bg-surface-muted border border-line rounded-lg p-4 text-xs text-code-text overflow-x-auto leading-relaxed"><%= toJson(activeGlobalPanel.data) %></pre>
              <% } %>
            </div>
          </div>

        <% } %>

      </div><!-- end content pane -->

    </div><!-- end two-column -->

  </main>
</body>
</html>
