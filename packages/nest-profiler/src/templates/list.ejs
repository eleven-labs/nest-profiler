<!DOCTYPE html>
<html lang="en">
<%- include('_head') %>
<body class="bg-background text-foreground min-h-screen font-mono text-sm antialiased">
  <%- include('_nav') %>
  <main class="max-w-7xl mx-auto px-6 py-8">

    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="text-base font-semibold text-foreground">Recent Profiles</h1>
        <p class="text-foreground-muted text-xs mt-0.5">HTTP requests captured by the profiler</p>
      </div>
      <span class="text-xs text-foreground-secondary bg-surface border border-line px-3 py-1.5 rounded-full tabular-nums">
        <%= profiles.length %> profile<%= profiles.length !== 1 ? 's' : '' %>
      </span>
    </div>

    <% if (heapSeries && heapSeries.length >= 2) { %>
      <%
        const heapMin  = Math.min(...heapSeries);
        const heapMax  = Math.max(...heapSeries);
        const heapSpan = heapMax - heapMin || 1;
        const heapLast = heapSeries[heapSeries.length - 1];
        // Trend: compare last 20% vs first 20% of the series
        const chunk = Math.max(1, Math.floor(heapSeries.length / 5));
        const heapAvgFirst = heapSeries.slice(0, chunk).reduce((s, v) => s + v, 0) / chunk;
        const heapAvgLast  = heapSeries.slice(-chunk).reduce((s, v) => s + v, 0) / chunk;
        const heapTrend    = heapAvgLast - heapAvgFirst;
        const trendClass   = heapTrend > 5 * 1024 * 1024 ? 'text-danger' : heapTrend > 1024 * 1024 ? 'dur-medium' : 'text-foreground-muted';
        const trendLabel   = heapTrend > 5 * 1024 * 1024 ? '↑ potential leak' : heapTrend > 1024 * 1024 ? '↑ growing' : '~ stable';
      %>
      <div class="mb-4 bg-surface border border-line rounded-xl p-4">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-3">
            <span class="text-xs font-semibold text-foreground">Process heap</span>
            <span class="text-2xs px-1.5 py-0.5 rounded bg-surface-muted border border-line text-foreground-faint">last <%= heapSeries.length %> requests</span>
          </div>
          <div class="flex items-center gap-4 text-xs tabular-nums">
            <span class="text-foreground-faint">min <span class="text-foreground"><%= mb(heapMin) %></span></span>
            <span class="text-foreground-faint">max <span class="text-foreground"><%= mb(heapMax) %></span></span>
            <span class="text-foreground-faint">now <span class="text-foreground font-medium"><%= mb(heapLast) %></span></span>
            <span class="<%= trendClass %> font-medium"><%= trendLabel %></span>
          </div>
        </div>
        <div class="flex items-end gap-px h-10">
          <% for (const v of heapSeries) { %>
            <%
              const pct = Math.round(((v - heapMin) / heapSpan) * 80) + 20;
              const barClass = v > heapMin + heapSpan * 0.8 ? 'bg-danger/60' : v > heapMin + heapSpan * 0.5 ? 'bg-amber-400/60' : 'bg-nest/40';
            %>
            <div class="flex-1 rounded-t-sm <%= barClass %>" style="height:<%= pct %>%"
                 title="<%= mb(v) %>"></div>
          <% } %>
        </div>
        <p class="text-foreground-faint text-2xs mt-2">Process-wide V8 heap at request start. A rising trend indicates a memory leak.</p>
      </div>
    <% } %>

    <form method="GET" action="<%= profilerPath %>" class="mb-4 flex flex-wrap gap-2 items-end bg-surface border border-line rounded-xl p-4">
      <div class="flex flex-col gap-1">
        <label class="text-foreground-faint text-2xs uppercase tracking-widest">Method</label>
        <select name="method" class="bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground focus:outline-none focus:border-nest">
          <option value="">All</option>
          <% for (const m of ['GET','POST','PUT','PATCH','DELETE','HEAD','OPTIONS']) { %>
            <option value="<%= m %>" <%= (filters && filters.method === m) ? 'selected' : '' %>><%= m %></option>
          <% } %>
        </select>
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-foreground-faint text-2xs uppercase tracking-widest">URL contains</label>
        <input type="text" name="url" value="<%= (filters && filters.url) ? filters.url : '' %>"
               placeholder="/api/…"
               class="bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground w-40 focus:outline-none focus:border-nest" />
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-foreground-faint text-2xs uppercase tracking-widest">Status</label>
        <input type="number" name="statusCode" value="<%= (filters && filters.statusCode) ? filters.statusCode : '' %>"
               placeholder="200"
               class="bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground w-20 focus:outline-none focus:border-nest" />
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-foreground-faint text-2xs uppercase tracking-widest">Min duration (ms)</label>
        <input type="number" name="minDuration" value="<%= (filters && filters.minDuration) ? filters.minDuration : '' %>"
               placeholder="0"
               class="bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground w-28 focus:outline-none focus:border-nest" />
      </div>
      <div class="flex flex-col gap-1">
        <label class="text-foreground-faint text-2xs uppercase tracking-widest">Max duration (ms)</label>
        <input type="number" name="maxDuration" value="<%= (filters && filters.maxDuration) ? filters.maxDuration : '' %>"
               placeholder="—"
               class="bg-surface-muted border border-line rounded px-2 py-1.5 text-xs text-foreground w-28 focus:outline-none focus:border-nest" />
      </div>
      <div class="flex gap-2">
        <button type="submit" class="px-3 py-1.5 rounded bg-nest text-white text-xs font-medium hover:opacity-90 transition-opacity">Filter</button>
        <a href="<%= profilerPath %>" class="px-3 py-1.5 rounded border border-line text-foreground-muted text-xs hover:text-foreground hover:border-line-active transition-colors">Reset</a>
      </div>
    </form>

    <% if (globalPanels && globalPanels.length > 0) { %>
      <% for (const gPanel of globalPanels) { %>
        <details class="group mb-4 rounded-xl border border-line bg-surface overflow-hidden" open>
          <summary class="flex items-center gap-2 px-4 py-3 cursor-pointer select-none bg-surface-muted hover:bg-surface-active transition-colors list-none">
            <svg class="w-3.5 h-3.5 text-foreground-muted transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
            <% if (gPanel.icon) { %><span class="w-3.5 h-3.5 shrink-0 text-foreground-muted"><%- gPanel.icon %></span><% } %>
            <span class="text-xs font-semibold text-foreground"><%= gPanel.label %></span>
            <span class="text-foreground-faint text-2xs ml-1 font-normal">— global, captured at startup</span>
          </summary>
          <div class="p-4 border-t border-line">
            <% if (gPanel.templatePath) { %>
              <%- include(gPanel.templatePath, { panel: gPanel, data: gPanel.data, highlightSql, toJson, isoDate, timeOnly }) %>
            <% } else { %>
              <pre class="bg-surface-muted border border-line rounded-lg p-4 text-xs text-code-text overflow-x-auto leading-relaxed"><%= toJson(gPanel.data) %></pre>
            <% } %>
          </div>
        </details>
      <% } %>
    <% } %>

    <div class="rounded-xl border border-line overflow-hidden bg-surface">
      <table class="w-full">
        <thead>
          <tr class="bg-surface-muted border-b border-line">
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Token</th>
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Method</th>
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">URL</th>
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Status</th>
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Duration</th>
            <th class="text-left py-3 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Time</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-line-subtle">
          <% if (profiles.length === 0) { %>
            <tr>
              <td colspan="6" class="py-16 text-center">
                <p class="text-foreground-muted text-sm mb-1">No profiles found</p>
                <p class="text-foreground-faint text-xs">Make HTTP requests to the API to start collecting data.</p>
              </td>
            </tr>
          <% } else { %>
            <% for (const p of profiles) { %>
              <%
                const dur = p.performance.duration;
                const durClass = dur === undefined ? 'dur-none'
                  : dur < 100  ? 'dur-fast'
                  : dur < 500  ? 'dur-medium'
                  : 'dur-slow';
              %>
              <tr class="hover:bg-surface-muted transition-colors">
                <td class="py-2.5 px-4">
                  <a href="<%= profilerPath %>/<%= p.token %>"
                     class="text-nest hover:text-nest-light transition-colors font-mono font-medium text-xs">
                    <%= p.token.slice(0, 8) %>
                  </a>
                </td>
                <td class="py-2.5 px-4">
                  <% if (p.request.graphql) { %>
                    <div class="flex items-center gap-1">
                      <span class="px-2 py-0.5 rounded text-2xs font-bold tracking-wide badge-default">GQL</span>
                      <span class="px-2 py-0.5 rounded text-2xs font-bold tracking-wide <%= gqlTypeClass(p.request.graphql.operationType) %>"><%= p.request.graphql.operationType.toUpperCase() %></span>
                    </div>
                  <% } else { %>
                    <span class="px-2 py-0.5 rounded text-2xs font-bold tracking-wide <%= methodClass(p.request.method) %>">
                      <%= p.request.method %>
                    </span>
                  <% } %>
                </td>
                <td class="py-2.5 px-4 text-foreground-secondary text-xs max-w-xs truncate" title="<%= p.request.url %>">
                  <% if (p.request.graphql) { %>
                    <span class="text-foreground-secondary"><%= p.request.graphql.operationName || p.request.graphql.fieldName %></span>
                    <span class="text-foreground-faint ml-1 text-2xs"><%= p.request.url %></span>
                  <% } else { %>
                    <%= p.request.url %>
                  <% } %>
                </td>
                <td class="py-2.5 px-4">
                  <% if (p.response) { %>
                    <span class="px-2 py-0.5 rounded text-2xs font-bold tracking-wide <%= statusClass(p.response.statusCode) %>">
                      <%= p.response.statusCode %>
                    </span>
                  <% } else { %>
                    <span class="text-foreground-faint text-xs">—</span>
                  <% } %>
                </td>
                <td class="py-2.5 px-4 text-xs tabular-nums">
                  <span class="<%= durClass %>"><%= dur !== undefined ? dur + 'ms' : '—' %></span>
                </td>
                <td class="py-2.5 px-4 text-foreground-faint text-xs tabular-nums"><%= isoDate(p.createdAt) %></td>
              </tr>
            <% } %>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>
</body>
</html>
