{
  "name": "@eleven-labs/nest-profiler",
  "version": "1.0.0-alpha.11",
  "description": "NestJS web profiler module inspired by Symfony's Web Profiler",
  "keywords": [
    "nestjs",
    "profiler",
    "web-profiler",
    "typescript",
    "debug",
    "performance",
    "monitoring",
    "devtools",
    "symfony-profiler",
    "nest-profiler",
    "web-debug-toolbar",
    "observability"
  ],
  "license": "MIT",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./sqlite": {
      "types": "./dist/storage/sqlite/index.d.ts",
      "require": "./dist/storage/sqlite/index.js",
      "default": "./dist/storage/sqlite/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs",
    "sqlite",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "repo-build && tsx ./scripts/build-assets.ts",
    "clean": "repo-clean dist coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit --incremental false && tsc --noEmit -p src/client/tsconfig.json"
  },
  "peerDependencies": {
    "@libsql/client": "^0.17.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "nestjs-cls": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@libsql/client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@highlightjs/cdn-assets": "11.11.1",
    "@libsql/client": "^0.17.4",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/testing": "^11.1.3",
    "@repo/build": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/cli": "^4.3.2",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/supertest": "^7.2.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.2.1",
    "nestjs-pino": "^4.4.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.1",
    "tailwindcss": "^4.3.2",
    "ts-jest": "^29.3.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "winston": "^3.19.0"
  },
  "jest": {
    "preset": "@repo/jest-config",
    "rootDir": ".",
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/index.ts",
      "!src/client/**"
    ],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "ejs": "^6.0.1"
  },
  "author": {
    "name": "Fabien Pasquet",
    "url": "https://github.com/fpasquet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-labs/nest-profiler.git",
    "directory": "packages/nest-profiler"
  },
  "homepage": "https://nest-profiler.eleven-labs.com/docs/packages/nest-profiler",
  "bugs": {
    "url": "https://github.com/eleven-labs/nest-profiler/issues"
  },
  "contributors": [
    {
      "name": "Eleven Labs",
      "url": "https://eleven-labs.com"
    }
  ],
  "funding": "https://eleven-labs.com"
}
