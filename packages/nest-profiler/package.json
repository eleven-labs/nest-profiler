{
  "name": "@eleven-labs/nest-profiler",
  "version": "0.3.0",
  "description": "NestJS web profiler module inspired by Symfony's Web Profiler",
  "keywords": [
    "nestjs",
    "profiler",
    "web-profiler",
    "typescript",
    "debug",
    "performance",
    "monitoring",
    "devtools",
    "symfony-profiler"
  ],
  "license": "MIT",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json && find src -name '*.ejs' | while IFS= read -r f; do dest=\"dist/${f#src/}\"; mkdir -p \"$(dirname \"$dest\")\" && cp \"$f\" \"$dest\"; done",
    "clean": "rimraf dist coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "nestjs-cls": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/testing": "^11.1.3",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.32",
    "@types/supertest": "^6.0.3",
    "jest": "^30.4.2",
    "nestjs-cls": "^4.5.0",
    "nestjs-pino": "^4.4.0",
    "pino-http": "^10.5.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "@repo/jest-config",
    "rootDir": ".",
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/index.ts"
    ],
    "coverageDirectory": "coverage"
  },
  "dependencies": {
    "ejs": "^6.0.1"
  },
  "author": "Fabien Pasquet",
  "repository": {
    "type": "git",
    "url": "https://github.com/eleven-labs/nest-profiler.git",
    "directory": "packages/nest-profiler"
  },
  "homepage": "https://github.com/eleven-labs/nest-profiler/tree/main/packages/nest-profiler#readme",
  "bugs": {
    "url": "https://github.com/eleven-labs/nest-profiler/issues"
  }
}
