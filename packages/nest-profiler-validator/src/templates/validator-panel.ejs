<%
  const entries = data || [];
  const invalidEntries = entries.filter(e => e.status === 'invalid');
  const validEntries = entries.filter(e => e.status === 'valid');
  const totalViolations = invalidEntries.reduce((acc, e) => acc + e.violationCount, 0);
  const sourceBadgeClass = { body: 'badge-post', query: 'badge-get', param: 'badge-put', custom: 'badge-default' };
%>

<% if (entries.length === 0) { %>
  <div class="py-8 text-center bg-surface-muted border border-line rounded-lg">
    <p class="text-foreground-muted text-sm mb-2">No validation performed during this request.</p>
    <p class="text-foreground-faint text-xs">
      Use <code class="bg-surface border border-line px-1.5 py-0.5 rounded">ValidatorCollectorModule.forRoot()</code>
      to enable the profiler validation pipe.
    </p>
  </div>
<% } else { %>

  <div class="grid grid-cols-3 gap-3 mb-6">
    <div class="bg-surface-muted border border-line rounded-lg p-4 text-center">
      <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1">Validated</p>
      <p class="text-foreground text-2xl font-bold tabular-nums"><%= entries.length %></p>
    </div>
    <div class="bg-surface-muted border border-line rounded-lg p-4 text-center">
      <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1">Valid</p>
      <p class="text-success text-2xl font-bold tabular-nums"><%= validEntries.length %></p>
    </div>
    <div class="bg-surface-muted border border-line rounded-lg p-4 text-center">
      <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1">Violations</p>
      <p class="<%= totalViolations > 0 ? 'text-danger' : 'text-foreground-faint' %> text-2xl font-bold tabular-nums"><%= totalViolations %></p>
    </div>
  </div>

  <div class="space-y-3">
    <% for (const entry of entries) { %>
      <%
        const isInvalid = entry.status === 'invalid';
        const borderClass = isInvalid ? 'border-danger-line bg-danger-bg/20' : 'border-line';
      %>
      <div class="rounded-lg border <%= borderClass %> overflow-hidden">

        <div class="flex items-center justify-between px-4 py-3 bg-surface-muted border-b border-line">
          <div class="flex items-center gap-3">
            <span class="px-1.5 py-0.5 rounded text-2xs font-bold tracking-wide <%= sourceBadgeClass[entry.source] || 'badge-default' %>">
              @<%= entry.source.toUpperCase() %>
            </span>
            <span class="text-foreground font-medium text-xs font-mono"><%= entry.dtoClass %></span>
            <time class="text-foreground-faint text-2xs tabular-nums"><%= timeOnly(entry.timestamp) %></time>
          </div>
          <% if (isInvalid) { %>
            <span class="px-2 py-0.5 rounded text-2xs font-bold bg-danger-bg text-danger border border-danger-line">
              <%= entry.violationCount %> violation<%= entry.violationCount !== 1 ? 's' : '' %>
            </span>
          <% } else { %>
            <span class="px-2 py-0.5 rounded text-2xs font-bold badge-2xx">VALID</span>
          <% } %>
        </div>

        <% if (isInvalid && entry.violations.length > 0) { %>
          <table class="w-full">
            <thead>
              <tr class="bg-surface border-b border-line">
                <th class="text-left py-2 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest w-1/4">Property</th>
                <th class="text-left py-2 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest w-1/4">Value</th>
                <th class="text-left py-2 px-4 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Constraints</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-line-subtle">
              <% for (const v of entry.violations) { %>
                <%- include('_violation-row', { v, depth: 0, toJson, timeOnly }) %>
              <% } %>
            </tbody>
          </table>
        <% } %>

      </div>
    <% } %>
  </div>

<% } %>
