{
  "name": "@eleven-labs/nest-profiler-http",
  "version": "1.0.0-alpha.7",
  "description": "HTTP client collector for @eleven-labs/nest-profiler — ships axios wiring, bring your own client",
  "keywords": [
    "nestjs",
    "http-client",
    "axios",
    "fetch",
    "profiler",
    "debug",
    "monitoring",
    "devtools",
    "nest-profiler",
    "web-debug-toolbar",
    "observability"
  ],
  "license": "MIT",
  "type": "commonjs",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "repo-build && tsx ./scripts/build-assets.ts",
    "clean": "repo-clean dist coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "test": "jest",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit --incremental false && tsc --noEmit -p src/client/tsconfig.json"
  },
  "peerDependencies": {
    "@eleven-labs/nest-profiler": ">=1.0.0-alpha.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "nestjs-cls": "^6.0.0",
    "reflect-metadata": "^0.2.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/axios": {
      "optional": true
    },
    "axios": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eleven-labs/nest-profiler": "workspace:*",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.3",
    "@nestjs/testing": "^11.1.3",
    "@repo/build": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "axios": "^1.18.1",
    "jest": "^30.4.2",
    "nestjs-cls": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "jest-environment-jsdom": "^30.4.1",
    "ts-jest": "^29.3.0",
    "tsx": "^4.20.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "@repo/jest-config",
    "rootDir": ".",
    "collectCoverageFrom": [
      "src/**/*.(t|j)s",
      "!src/index.ts",
      "!src/client/**"
    ],
    "coverageDirectory": "coverage"
  },
  "author": {
    "name": "Fabien Pasquet",
    "url": "https://github.com/fpasquet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-labs/nest-profiler.git",
    "directory": "packages/nest-profiler-http"
  },
  "homepage": "https://nest-profiler.eleven-labs.com/docs/packages/nest-profiler-http",
  "bugs": {
    "url": "https://github.com/eleven-labs/nest-profiler/issues"
  },
  "contributors": [
    {
      "name": "Eleven Labs",
      "url": "https://eleven-labs.com"
    }
  ],
  "funding": "https://eleven-labs.com"
}
