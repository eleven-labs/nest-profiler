<%
  const groups = (data && Array.isArray(data.groups)) ? data.groups : [];
  const routeCount = (data && typeof data.routeCount === 'number')
    ? data.routeCount
    : groups.reduce((n, g) => n + ((g && g.routes) ? g.routes.length : 0), 0);

  /* Tailwind classes per HTTP method / operation verb, mirroring the request list badges. */
  function methodClass(method) {
    switch (String(method || '').toUpperCase()) {
      case 'GET':    return 'bg-emerald-100 border-emerald-200 text-emerald-700 dark:bg-emerald-900/30 dark:border-emerald-800 dark:text-emerald-300';
      case 'POST':   return 'bg-amber-100 border-amber-200 text-amber-700 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-300';
      case 'PUT':
      case 'PATCH':  return 'bg-blue-100 border-blue-200 text-blue-700 dark:bg-blue-900/30 dark:border-blue-800 dark:text-blue-300';
      case 'DELETE': return 'bg-danger-bg border-danger-line text-danger';
      default:       return 'bg-surface border-line text-foreground-muted';
    }
  }

  function hasInputs(inputs) {
    if (!inputs) return false;
    return (inputs.params && inputs.params.length) || (inputs.query && inputs.query.length)
      || (inputs.headers && inputs.headers.length) || inputs.body;
  }
%>

<% if (routeCount === 0) { %>
  <div class="py-8 text-center bg-surface-muted border border-line rounded-lg space-y-2 px-6">
    <p class="text-foreground-muted text-sm font-medium">No routes discovered.</p>
    <p class="text-foreground-faint text-xs leading-relaxed">
      This panel lists every registered route (REST controllers plus GraphQL / RabbitMQ / CLI when
      their profiler packages are installed). It is populated at application startup.
    </p>
  </div>
<% } else { %>
  <div class="flex items-center gap-2 mb-3">
    <h3 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold">Registered routes</h3>
    <span class="text-2xs px-1.5 py-0.5 rounded-full bg-surface-muted border border-line text-foreground-faint tabular-nums"><%= routeCount %> routes</span>
  </div>

  <% for (const group of groups) { %>
    <details class="group mb-3 rounded-lg border border-line overflow-hidden" open>
      <summary class="flex items-center justify-between gap-3 px-4 py-2.5 cursor-pointer select-none bg-surface-muted hover:bg-surface-active transition-colors list-none">
        <div class="flex items-center gap-2 min-w-0">
          <svg class="w-3.5 h-3.5 text-foreground-muted transition-transform group-open:rotate-90 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <% if (group.icon) { %><span class="w-3.5 h-3.5 shrink-0 text-foreground-muted"><%- group.icon %></span><% } %>
          <span class="text-xs font-semibold text-foreground truncate"><%= group.label %></span>
        </div>
        <span class="text-2xs px-1.5 py-0.5 rounded-full bg-surface border border-line text-foreground-faint tabular-nums shrink-0"><%= group.routes.length %> routes</span>
      </summary>

      <div class="border-t border-line divide-y divide-line-subtle">
        <% for (const route of group.routes) { %>
          <% const guards = route.guards || []; %>
          <% const expandable = hasInputs(route.inputs) || guards.length > 0; %>
          <details class="group/route">
            <summary class="flex items-center gap-3 px-4 py-2.5 select-none list-none <%= expandable ? 'cursor-pointer hover:bg-surface-muted' : 'cursor-default' %> transition-colors">
              <% if (expandable) { %>
                <svg class="w-3 h-3 text-foreground-faint transition-transform group-open/route:rotate-90 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              <% } else { %>
                <span class="w-3 h-3 shrink-0"></span>
              <% } %>
              <span class="text-2xs font-bold uppercase tracking-wide px-1.5 py-0.5 rounded border tabular-nums shrink-0 <%= methodClass(route.method) %>"><%= route.method %></span>
              <span class="text-xs font-mono text-foreground truncate flex-1"><%= route.path %></span>
              <% if (guards.length) { %>
                <span class="shrink-0 text-amber-600 dark:text-amber-400" title="Protected by <%= guards.join(', ') %>" aria-label="Protected route">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 1a4 4 0 00-4 4v2H5a2 2 0 00-2 2v6a2 2 0 002 2h10a2 2 0 002-2V9a2 2 0 00-2-2h-1V5a4 4 0 00-4-4zM8 7V5a2 2 0 114 0v2H8z" clip-rule="evenodd"/></svg>
                </span>
              <% } %>
              <span class="text-2xs text-foreground-faint font-mono truncate shrink-0 max-w-[40%]"><%= route.controller %>.<%= route.handler %></span>
            </summary>

            <% if (expandable) { %>
              <div class="px-4 pb-3 pt-1 pl-10 space-y-3 bg-surface-muted/50">
                <% const inputs = route.inputs || {}; %>

                <% if (guards.length) { %>
                  <div>
                    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1.5">Guards</p>
                    <div class="flex flex-wrap gap-1.5">
                      <% for (const guard of guards) { %>
                        <span class="text-2xs px-1.5 py-0.5 rounded bg-amber-100 border border-amber-200 text-amber-700 dark:bg-amber-900/30 dark:border-amber-800 dark:text-amber-300 font-mono"><%= guard %></span>
                      <% } %>
                    </div>
                  </div>
                <% } %>

                <% for (const chip of [['Path params', inputs.params], ['Query params', inputs.query], ['Headers', inputs.headers]]) { %>
                  <% const [chipTitle, chipNames] = chip; %>
                  <% if (chipNames && chipNames.length) { %>
                    <div>
                      <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1.5"><%= chipTitle %></p>
                      <div class="flex flex-wrap gap-1.5">
                        <% for (const name of chipNames) { %>
                          <span class="text-2xs px-1.5 py-0.5 rounded bg-surface border border-line text-foreground-muted font-mono"><%= name %></span>
                        <% } %>
                      </div>
                    </div>
                  <% } %>
                <% } %>

                <% if (inputs.body) { %>
                  <div>
                    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-1.5">
                      Body — <span class="text-foreground-muted font-mono normal-case tracking-normal"><%= inputs.body.name %></span>
                    </p>
                    <% if (inputs.body.properties && inputs.body.properties.length) { %>
                      <div class="rounded-lg border border-line overflow-hidden">
                        <table class="w-full">
                          <thead>
                            <tr class="border-b border-line bg-surface">
                              <th class="text-left py-2 px-3 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Property</th>
                              <th class="text-left py-2 px-3 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Type</th>
                              <th class="text-left py-2 px-3 text-foreground-muted font-medium text-2xs uppercase tracking-widest">Rules</th>
                            </tr>
                          </thead>
                          <tbody class="divide-y divide-line-subtle">
                            <% for (const prop of inputs.body.properties) { %>
                              <tr class="hover:bg-surface transition-colors">
                                <td class="py-1.5 px-3 text-xs font-mono text-foreground align-top">
                                  <%= prop.name %><% if (prop.optional) { %><span class="text-foreground-faint">?</span><% } %>
                                </td>
                                <td class="py-1.5 px-3 text-xs font-mono text-nest align-top"><%= prop.tsType %></td>
                                <td class="py-1.5 px-3 text-xs align-top">
                                  <% if (prop.rules && prop.rules.length) { %>
                                    <div class="flex flex-wrap gap-1">
                                      <% for (const rule of prop.rules) { %>
                                        <span class="text-2xs px-1 py-0.5 rounded bg-surface border border-line text-foreground-faint font-mono"><%= rule %></span>
                                      <% } %>
                                    </div>
                                  <% } else { %>
                                    <span class="text-foreground-faint">—</span>
                                  <% } %>
                                </td>
                              </tr>
                            <% } %>
                          </tbody>
                        </table>
                      </div>
                    <% } else { %>
                      <p class="text-foreground-faint text-2xs italic">No introspectable properties (install <code class="bg-surface border border-line px-1 rounded">class-validator</code> to surface the DTO shape).</p>
                    <% } %>
                  </div>
                <% } %>
              </div>
            <% } %>
          </details>
        <% } %>
      </div>
    </details>
  <% } %>
<% } %>
