<%
  const cmd = profile.entrypoint.data;
  const cmdDur = profile.performance.duration;
  const cmdOptions = cmd.options || {};
  const cmdError = profile.exceptions.length > 0 ? profile.exceptions[0].message : null;
%>

<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
  <div class="bg-surface-muted border border-line rounded-lg p-4">
    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-2">Status</p>
    <p class="text-xl font-bold <%= cmd.success ? 'text-success' : 'text-danger' %>"><%= cmd.success ? 'OK' : 'Failed' %></p>
  </div>
  <div class="bg-surface-muted border border-line rounded-lg p-4">
    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-2">Exit Code</p>
    <p class="text-foreground text-xl font-bold tabular-nums"><%= cmd.exitCode %></p>
  </div>
  <div class="bg-surface-muted border border-line rounded-lg p-4">
    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-2">Duration</p>
    <p class="text-foreground text-xl font-bold tabular-nums"><%= cmdDur !== undefined ? cmdDur + 'ms' : '—' %></p>
  </div>
  <div class="bg-surface-muted border border-line rounded-lg p-4">
    <p class="text-foreground-faint text-2xs uppercase tracking-widest mb-2">Started</p>
    <p class="text-foreground text-sm font-bold tabular-nums"><%= timeOnly(profile.performance.startTime) %></p>
  </div>
</div>

<section class="mb-6">
  <h2 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold mb-3">Command</h2>
  <code class="block bg-surface-muted border border-line rounded-lg px-4 py-3 text-foreground text-sm break-all">
    <span class="px-1.5 py-0.5 rounded text-2xs font-bold tracking-wide badge-default mr-2">CLI</span><%= cmd.name %><% if (cmd.arguments.length) { %> <%= cmd.arguments.join(' ') %><% } %>
  </code>
</section>

<section class="mb-6">
  <h2 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold mb-3">Arguments</h2>
  <% if (!cmd.arguments.length) { %>
    <p class="text-foreground-faint text-xs italic py-1">No positional arguments.</p>
  <% } else { %>
    <div class="flex flex-wrap gap-2">
      <% for (const arg of cmd.arguments) { %>
        <span class="px-2 py-1 rounded text-xs bg-surface-muted border border-line text-foreground-secondary"><%= arg %></span>
      <% } %>
    </div>
  <% } %>
</section>

<section <%= cmdError ? 'class="mb-6"' : '' %>>
  <h2 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold mb-3">Options</h2>
  <% if (Object.keys(cmdOptions).length === 0) { %>
    <p class="text-foreground-faint text-xs italic py-1">No options.</p>
  <% } else { %>
    <%- kvTable(cmdOptions) %>
  <% } %>
</section>

<% if (cmdError) { %>
  <section>
    <h2 class="text-foreground-muted text-2xs uppercase tracking-widest font-semibold mb-3">Error</h2>
    <pre class="bg-danger-bg border border-danger-line rounded-lg px-4 py-3 text-danger text-xs whitespace-pre-wrap break-all"><%= cmdError %></pre>
  </section>
<% } %>
