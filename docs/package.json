{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "fumadocs-mdx && next build",
    "clean": "repo-clean .next .source",
    "dev": "fumadocs-mdx && next dev --port 3002",
    "format": "prettier --write \"{app,components,content,lib,messages}/**/*.{ts,tsx,css,json,mdx}\" \"*.{ts,json,mjs}\"",
    "format:check": "prettier --check \"{app,components,content,lib,messages}/**/*.{ts,tsx,css,json,mdx}\" \"*.{ts,json,mjs}\"",
    "lint": "eslint .",
    "start": "next start --port 3002",
    "typecheck": "fumadocs-mdx && tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.19",
    "class-variance-authority": "^0.7.1",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "fumadocs-core": "^16.11.1",
    "fumadocs-mdx": "^15.1.0",
    "fumadocs-typescript": "^5.3.0",
    "fumadocs-ui": "^16.11.1",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.2.4",
    "@repo/build": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.16",
    "shiki": "^4.3.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
