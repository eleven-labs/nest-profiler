{
  "name": "nest-profiler-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS profiler toolkit — pnpm + Turbo monorepo for @eleven-labs/nest-profiler and its collector packages.",
  "license": "MIT",
  "author": {
    "name": "Fabien Pasquet",
    "url": "https://github.com/fpasquet"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-labs/nest-profiler.git"
  },
  "homepage": "https://github.com/eleven-labs/nest-profiler#readme",
  "bugs": {
    "url": "https://github.com/eleven-labs/nest-profiler/issues"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "turbo run build",
    "docs:build": "pnpm --filter docs build",
    "docs:dev": "pnpm --filter docs dev",
    "example:dev": "turbo run start:dev --filter=example-api",
    "example:start": "turbo run build && pnpm --filter=example-api start",
    "screenshots": "tsx scripts/generate-profiler-screenshots.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v",
    "clean": "turbo run clean && rm -rf node_modules .turbo coverage",
    "changeset": "changeset",
    "changeset:sync-changelog": "tsx scripts/changesets/fill-synced-changelog.ts",
    "changeset:pre:alpha": "changeset pre enter alpha",
    "changeset:pre:beta": "changeset pre enter beta",
    "changeset:pre:exit": "changeset pre exit",
    "format": "prettier --write \".github/**/*.{md,yml,json}\" \".changeset/*.json\" \"*.{json,md,mjs,yaml}\" \"scripts/**/*.{json,md,ts}\" && turbo run format",
    "format:check": "prettier --check \".github/**/*.{md,yml,json}\" \".changeset/*.json\" \"*.{json,md,mjs,yaml}\" \"scripts/**/*.{json,md,ts}\" && turbo run format:check",
    "lint": "turbo run lint",
    "pack:dry-run": "pnpm -r --filter './packages/**' --filter '!@repo/*' exec npm pack --dry-run",
    "publint": "pnpm -r --filter './packages/**' --filter '!@repo/*' exec publint",
    "attw": "pnpm -r --filter './packages/**' --filter '!@repo/*' --filter '!@eleven-labs/nest-profiler-mikro-orm' exec attw --pack && pnpm --filter @eleven-labs/nest-profiler-mikro-orm exec attw --pack --ignore-rules cjs-resolves-to-esm",
    "release": "tsx scripts/changesets/publish.ts",
    "release:alpha": "tsx scripts/changesets/publish.ts alpha",
    "release:beta": "tsx scripts/changesets/publish.ts beta",
    "release:stable": "tsx scripts/changesets/publish.ts stable",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov",
    "test:e2e": "turbo run test:e2e",
    "typecheck": "turbo run typecheck",
    "version-packages": "changeset version && pnpm changeset:sync-changelog",
    "prepare": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "publint": "^0.3.12",
    "tsx": "^4.20.3",
    "turbo": "^2.10.2",
    "typescript": "^6.0.3"
  },
  "contributors": [
    {
      "name": "Eleven Labs",
      "url": "https://eleven-labs.com"
    }
  ],
  "funding": "https://eleven-labs.com",
  "keywords": [
    "nestjs",
    "profiler",
    "web-profiler",
    "devtools",
    "monitoring",
    "observability",
    "nest-profiler"
  ]
}
