# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Start with: pnpm docker:up (from project root)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=profiler
DATABASE_PASSWORD=profiler
DATABASE_NAME=profiler_example

# MongoDB (Mongoose — run: docker compose up -d mongodb)
MONGODB_URI=mongodb://localhost:27017/profiler_example

# Profiler security (optional — leave empty for open access in dev)
# PROFILER_TOKEN=your-secret-token

# Feature flags
# SQL_ORM selects the products persistence adapter (mutually exclusive, same Postgres table):
#   typeorm | mikro-orm | none
SQL_ORM=typeorm
FEATURE_MONGOOSE=true
PROFILER_ENABLED=true
# Use 'file' storage so CLI command profiles (pnpm cli sync:posts) are visible
# in the HTTP app's web profiler at /_profiler.
PROFILER_STORAGE_TYPE=file
PROFILER_STORAGE_PATH=.profiler
