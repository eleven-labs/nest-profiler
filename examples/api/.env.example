# Example API — environment variables.
# Every variable the app reads is listed below with its default. This file turns the full feature
# set on for local development (needs Docker); copy it to `.env` and adjust. A bare run with no
# `.env` boots the minimal, zero-infrastructure set (in-memory catalog + GraphQL, content, auth).

# ── Application ──────────────────────────────────────────────────────────────
# HTTP port. Default: 3000
PORT=3000
# development | production. Default: development
NODE_ENV=development
# Pino log level, only used when FEATURE_PINO_LOGGER=true. Default: debug (dev) / info (production)
# LOG_LEVEL=debug

# ── Feature flags ────────────────────────────────────────────────────────────
# Catalog persistence adapter. `in-memory` (default) needs no database, so the catalog + GraphQL run
# out of the box; `typeorm`/`mikro-orm` are mutually exclusive (same Postgres table).
# Values: in-memory | typeorm | mikro-orm
SQL_ORM=typeorm
# Content HTTP client backing the ArticleGateway — selects which HTTP Client instrumentation captures
# outgoing calls (axios via @nestjs/axios, or native fetch). Default: axios
# Values: axios | fetch
HTTP_CLIENT=axios
# Mongoose-backed reviews (needs MongoDB). Opt-in. Default: false
FEATURE_MONGOOSE=true
# GraphQL API over the catalog (served over any adapter, no infrastructure). Default: true (on)
FEATURE_GRAPHQL=true
# RabbitMQ review.created producer/consumer + nest-profiler-rabbitmq (needs a broker). Default: false
FEATURE_RABBITMQ=true
# Use the third-party nestjs-pino logger (JSON logs) instead of the Nest ConsoleLogger. Default: false
FEATURE_PINO_LOGGER=false
# Batch the GraphQL Product.reviews resolver with a per-request DataLoader (one query instead of N).
# Compare the profiler trace with it off (N+1) vs on (batched). Default: false
FEATURE_DATALOADER=false

# ── Profiler ─────────────────────────────────────────────────────────────────
# Enable the profiler UI + collectors; false loads the zero-cost no-op fallback. Default: true
PROFILER_ENABLED=true
# Storage backend: memory | file | sqlite. `file` and `sqlite` are cross-process, so CLI command
# profiles show up in the HTTP app's web profiler at /_profiler; `sqlite` filters and paginates in
# the database (requires `pnpm add @libsql/client`). Default: file
PROFILER_STORAGE_TYPE=file
# `file`: profiles directory. `sqlite`: local database file (default .profiler/profiler.db). Ignored
# when PROFILER_STORAGE_URL is set. Default: .profiler
PROFILER_STORAGE_PATH=.profiler
# Seconds before a stored profile expires (file/sqlite storage). Default: 3600
PROFILER_TTL=3600
# Maximum profiles kept (LRU eviction). Default: 200
PROFILER_MAX_PROFILES=200
# Remote SQLite database for PROFILER_STORAGE_TYPE=sqlite. When set, the SQLite adapter targets this
# remote database instead of the local file — same adapter. Leave empty for a local database. On
# Vercel these fall back to the Turso integration's TURSO_DATABASE_URL / TURSO_AUTH_TOKEN.
# PROFILER_STORAGE_URL=libsql://your-database.example.com
# PROFILER_STORAGE_AUTH_TOKEN=your-auth-token
# Access control guarding /_profiler in the demo (like SQL_ORM picks an adapter). Off by default.
#   basic → HTTP Basic auth with PROFILER_BASIC_USER / PROFILER_BASIC_PASSWORD (browser prompt / curl -u)
#   token → bearer or ?token=<PROFILER_TOKEN> (query threaded across UI links via linkQuery)
#   cookie→ reuse the app's JwtAuthGuard (security.guards). GET /api/v1/auth/token sets a JWT cookie
#           the browser sends on every link, so /_profiler is navigable (Bearer header also accepted)
# PROFILER_AUTH=basic
# Credentials for PROFILER_AUTH=basic (username defaults to `admin`).
# PROFILER_BASIC_USER=admin
# PROFILER_BASIC_PASSWORD=your-secret-password
# Secret for PROFILER_AUTH=token.
# PROFILER_TOKEN=your-secret-token

# ── Database (PostgreSQL — only used when SQL_ORM=typeorm|mikro-orm) ──────────
# Start with: pnpm docker:up (from the project root)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=profiler
DATABASE_PASSWORD=profiler
DATABASE_NAME=profiler_example
# Enable SSL for hosted Postgres providers such as Neon. PGSSLMODE=require is also supported. On
# Vercel the app also falls back to the Neon integration's POSTGRES_* / PG* variables.
DATABASE_SSL=false
# Schema management (the demo has no migrations). Both default to NODE_ENV !== 'production':
# outside production the ORM creates the table and drops-and-recreates it on boot (clean slate when
# switching SQL_ORM); on a hosted deploy set DATABASE_SYNCHRONIZE=true to create the schema without
# the destructive drop. Override explicitly if needed.
# DATABASE_SYNCHRONIZE=true
# DATABASE_DROP_SCHEMA=false

# ── MongoDB (only used when FEATURE_MONGOOSE=true — run: docker compose up -d mongodb) ──
MONGODB_URI=mongodb://localhost:27017/profiler_example

# ── RabbitMQ (only used when FEATURE_RABBITMQ=true — run: docker compose up -d rabbitmq) ──
RABBITMQ_URI=amqp://profiler:profiler@localhost:5672
