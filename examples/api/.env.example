# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
# Start with: pnpm docker:up (from project root)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=profiler
DATABASE_PASSWORD=profiler
DATABASE_NAME=profiler_example

# MongoDB (Mongoose — run: docker compose up -d mongodb)
MONGODB_URI=mongodb://localhost:27017/profiler_example

# RabbitMQ (only used when FEATURE_RABBITMQ=true — run: docker compose up -d rabbitmq)
RABBITMQ_URI=amqp://profiler:profiler@localhost:5672

# Profiler security (optional — leave empty for open access in dev)
# PROFILER_TOKEN=your-secret-token

# Feature flags
# SQL_ORM selects the catalog persistence adapter. `in-memory` (default) needs no database, so the
# catalog + GraphQL run out of the box; `typeorm`/`mikro-orm` are mutually exclusive (same Postgres
# table). Values: in-memory | typeorm | mikro-orm
SQL_ORM=typeorm
# Opt-in: Mongoose-backed reviews (needs MongoDB). Off by default so a bare deploy needs no database.
FEATURE_MONGOOSE=true
# Opt-in: GraphQL API over the catalog. On by default (served over the in-memory catalog, no infra).
FEATURE_GRAPHQL=true
# Opt-in: RabbitMQ review.created consumer/producer + nest-profiler-rabbitmq (needs a broker).
FEATURE_RABBITMQ=true
PROFILER_ENABLED=true
# Use 'file' storage so CLI command profiles (pnpm cli content:sync) are visible
# in the HTTP app's web profiler at /_profiler.
PROFILER_STORAGE_TYPE=file
PROFILER_STORAGE_PATH=.profiler
# Seconds before a stored profile expires (file storage only, default: 3600)
PROFILER_TTL=3600
