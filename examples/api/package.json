{
  "name": "example-api",
  "version": "0.0.0",
  "private": true,
  "prettier": "@repo/prettier-config",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint src",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "test": "echo 'No tests for example-api'",
    "typecheck": "tsc --noEmit --incremental false"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cache-manager": "^3.0.1",
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/typeorm": "^11.0.1",
    "@eleven-labs/nest-profiler": "workspace:*",
    "@eleven-labs/nest-profiler-auth": "workspace:*",
    "@eleven-labs/nest-profiler-axios": "workspace:*",
    "@eleven-labs/nest-profiler-cache": "workspace:*",
    "@eleven-labs/nest-profiler-config": "workspace:*",
    "@eleven-labs/nest-profiler-mongoose": "workspace:*",
    "@eleven-labs/nest-profiler-typeorm": "workspace:*",
    "@eleven-labs/nest-profiler-validator": "workspace:*",
    "@nestjs/swagger": "^11.0.0",
    "axios": "^1.9.0",
    "@nestjs/mongoose": "^11.0.1",
    "cache-manager": "^6.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "nestjs-cls": "^4.5.0",
    "mongoose": "^8.15.0",
    "pg": "^8.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.24"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/prettier-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.32",
    "@nestjs/cli": "^11.0.7",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
