{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["GITHUB_TOKEN"],
      "inputs": [
        "app/**",
        "build/**",
        "content/**",
        "lib/**",
        "messages/**",
        "src/**",
        "next.config.ts",
        "source.config.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "package.json"
      ],
      "outputs": [".next/**", ".source/**", "dist/**"]
    },
    "clean": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["app/**", "content/**", "lib/**", "src/**", "eslint.config.mjs", "package.json"]
    },
    "start:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json"]
    },
    "test:cov": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "package.json"],
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": [
        "app/**",
        "content/**",
        "lib/**",
        "messages/**",
        "src/**",
        "test/**",
        "tsconfig.json",
        "package.json"
      ]
    }
  }
}
